# Copy this file to .env and fill in your keys.

# --- Groq (the AI brain, free tier) ---
# Get a free key at https://console.groq.com -> API Keys.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# Llama 3.3 70B supports tool calling and is fast. Other options:
# llama-3.1-8b-instant (faster/cheaper), llama-3.3-70b-versatile (default).
GROQ_MODEL=llama-3.3-70b-versatile

# --- Twilio (WhatsApp + phone calls) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
# Your Twilio WhatsApp sender, e.g. whatsapp:+14155238886 (sandbox) or your number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Google Calendar (for real bookings) ---
# Path to the service account JSON key file you downloaded.
GOOGLE_SERVICE_ACCOUNT_KEY=./google-service-account.json
# The calendar to book into (often the owner's email, or from calendar settings).
GOOGLE_CALENDAR_ID=your-calendar@gmail.com
# IANA timezone for the business, e.g. America/Chicago, Asia/Seoul, Asia/Kolkata.
BUSINESS_TIMEZONE=America/Chicago

# --- Reminders ---
# Send a WhatsApp reminder when an appointment is within this many hours.
REMINDER_HOURS_BEFORE=24
# How often (minutes) the server checks for due reminders.
REMINDER_INTERVAL_MIN=15

# --- Server ---
PORT=3000
